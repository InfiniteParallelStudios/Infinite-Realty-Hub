# Environment Variables Template
# Copy this file to .env and fill in your specific values

# Development Environment
NODE_ENV=development
DEBUG=true

# React Native Metro Server
METRO_HOST=localhost
METRO_PORT=8081

# API Configuration (Update these when backend is ready)
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=10000

# Authentication (Update these when auth service is ready)
AUTH_SECRET_KEY=your-secret-key-here
JWT_EXPIRES_IN=7d

# Database (For future backend development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=infinite_realty_hub_dev
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# External Services (Add API keys when needed)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Push Notifications (For future implementation)
FCM_SERVER_KEY=your-fcm-server-key
APNS_KEY_ID=your-apns-key-id

# Analytics (Optional)
ANALYTICS_ENABLED=true
SENTRY_DSN=your-sentry-dsn

# Development Flags
ENABLE_FLIPPER=true
ENABLE_HERMES=true
ENABLE_NEW_ARCH=false

# Android Development
ANDROID_HOME=C:\Users\joshu\AppData\Local\Android\Sdk
JAVA_HOME=C:\Program Files\Android\Android Studio\jbr

# iOS Development (For macOS developers)
# DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
